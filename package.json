{
  "name": "inhouse-bot",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "register:guild": "tsx scripts/register-commands.ts --scope guild",
    "register:global": "tsx scripts/register-commands.ts --scope global",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "discord.js": "^14.16.3",
    "dotenv": "^17.2.1",
    "pino": "^9.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
